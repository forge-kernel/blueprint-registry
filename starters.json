    "auth": {
      "name": "Auth Starter",
      "description": "",
      "latest": "1.0.0",
      "versions": {
        "1.0.0": {
          "url": "auth/1.0.0",
          "integrity": "b42208cff9362bd7bf53a5f01fbd4f11503844d5356309452ff9a08be7b158b9",
          "kernel": "latest",
          "modules": {
            "forge-package-manager": "latest"
          },
          "post_install": ["php forge.php db:migrate --type=all"],
          "config": {
            "options": [
              {
                "key": "architecture",
                "label": "Auth Architecture",
                "type": "select",
                "required": true,
                "default": "modular",
                "options": [
                  {
                    "value": "modular",
                    "label": "Modular",
                    "description": "Auth, landing, and admin provided by installable modules (ForgeAppAuth, ForgeLanding, ForgeAdminConsole)",
                    "modules": {
                      "forge-app-auth": "latest",
                      "forge-landing": "latest",
                      "forge-admin-console": "latest"
                    }
                  },
                  {
                    "value": "monolithic",
                    "label": "Monolithic",
                    "description": "Auth, landing, and admin code lives directly in app/"
                  }
                ]
              }
            ]
          }
        }
      }
